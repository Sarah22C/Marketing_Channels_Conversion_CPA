  <dashboards>
    <dashboard name='Story 1' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1'>Marketing Channels Average CPA &amp; Conversion Rate By Age</run>
          </formatted-text>
        </title>
      </layout-options>
      <style>
        <style-rule element='story-description'>
          <format attr='background-color' id='story-description_6' value='#e6ecf0d9' />
        </style-rule>
        <style-rule element='story-point-caption'>
          <format attr='width' value='331' />
        </style-rule>
      </style>
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97856' id='1' param='vert' removable='false' type-v2='layout-flow' w='99002' x='499' y='1072'>
            <zone h='6568' id='3' type-v2='title' w='99002' x='499' y='1072' />
            <zone h='13539' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99002' x='499' y='7640' />
            <zone h='77749' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99002' x='499' y='21179'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Age Segmentation Reveals 35–44 as Highest Leverage Segment' captured-sheet='Overview Age' id='1' />
                  <story-point caption='Conversion-Stage Campaigns Reduce CPA in 35–44' captured-sheet='Campaign Type 35-44' id='3' />
                  <story-point caption='Social Media Delivers Lowest CPA Within Conversion Stage of 35-44' captured-sheet='Conversion + Channel 35-44' id='2' />
                  <story-point caption='Key Findings &amp; Recommendations' captured-sheet='' id='5' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='70777' hidden='true' id='6' story-point-id='5' type-v2='text' w='88716' x='5549' y='23056'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='18'>Key Findings:</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='18'>• 35–44 combines strong conversion performance with high spend leverage</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='18'>• Conversion-stage campaigns reduce CPA by ~$1,000 vs Awareness</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='18'>• Within Conversion stage, Social Media delivers the lowest CPA</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='18'>Recommendations:</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='18'>• Conduct a controlled budget reallocation test within the 35–44 segment</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='18'>• Shift incremental spend from Awareness and upper-funnel Email campaigns to Conversion-stage Social Media campaigns</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' fontsize='18'>• Monitor marginal CPA and conversion volume over 30–60 days to validate efficiency stability</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{D4FE12A2-3F97-41A2-945F-83CAD2936A5B}' />
    </dashboard>
  </dashboards>
